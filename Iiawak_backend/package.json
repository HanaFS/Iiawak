{
  "name": "iiawak-backend",
  "version": "2.0.0",
  "description": "Backend API đầy đủ cho Iiawak Mobile + Web Admin",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed.js",
    "migrate:up": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "migrate:status": "node scripts/migrate.js status",
    "indexes:create": "node scripts/createIndexes.js",
    "backup": "bash scripts/backup.sh backup",
    "backup:restore": "bash scripts/backup.sh restore",
    "backup:list": "bash scripts/backup.sh list",
    "backup:clean": "bash scripts/backup.sh clean",
    "test": "jest --passWithNoTests --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "smoke-tests": "bash scripts/smoke-tests.sh"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "rate-limit-redis": "^4.1.5",
    "redis": "^4.6.11",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
