# ─────────────────────────────────────────────────────────────
# Iiawak Backend Environment Variables Template (.env.example)
# Copy to .env and fill in actual values
# ─────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/iiawak

# ─── Authentication (JWT) ────────────────────────────────────
JWT_SECRET=iiawak_super_secret_key_2026_please_change_in_production
JWT_EXPIRES_IN=7d

# ─── AI (Gemini) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Cloud Storage (Cloudinary) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Payment Gateway (VNPay) ─────────────────────────────────
# Get these from VNPay merchant panel: https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paygate
VNPAY_RETURN_URL=http://localhost:3000/payment-result
VNPAY_API=https://api.vnpayment.vn/

# ─── CORS ────────────────────────────────────────────────────
ADMIN_URL=http://localhost:5173

# ─── Redis (Optional - for caching) ──────────────────────────
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_PASSWORD=

# ─── Email Service (Optional - for notifications) ────────────
# EMAIL_PROVIDER=gmail|sendgrid|nodemailer
# EMAIL_FROM=noreply@iiawak.com
# EMAIL_PASSWORD=your_email_password
# SENDGRID_API_KEY=your_sendgrid_api_key

# ─── SMS Service (Optional - Twilio for OTP) ──────────────────
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── Error Tracking (Optional - Sentry) ──────────────────────
# SENTRY_DSN=https://your_sentry_dsn

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs
