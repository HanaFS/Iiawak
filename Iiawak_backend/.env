# ========================
# Iiawak Backend Config
# ========================

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/iiawak

# JWT Secret (thay bằng chuỗi bí mật riêng của bạn)
JWT_SECRET=iiawak_super_secret_key_2026

# Server
PORT=5000

# Google Gemini AI (đăng ký tại https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Dashboard URL (để CORS)
ADMIN_URL=http://localhost:5173

# ─── Cloudinary (File/Image Storage) ─────────────────────────────────────────
# Đăng ký tại: https://cloudinary.com (Free tier: 25GB storage, 25GB bandwidth/tháng)
# Vào Dashboard → API Keys → Copy 3 giá trị dưới đây
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret