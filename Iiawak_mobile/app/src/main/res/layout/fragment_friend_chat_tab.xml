<?xml version="1.0" encoding="utf-8"?>
<!-- Tab Bạn bè: chat người với người (cần follow nhau) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Thông báo yêu cầu bạn bè -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/friend_request_card"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="14dp"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_notification_pixel" />

            <TextView
                android:id="@+id/friend_request_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bạn có lời mời kết bạn mới"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_requests"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Xem"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:background="@drawable/bg_button_gradient"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="100dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Danh sách chat bạn bè -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/friend_chat_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <!-- Loading State -->
        <ProgressBar
            android:id="@+id/friend_chat_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/brand_primary"
            android:visibility="gone" />

        <!-- Empty state khi chưa có bạn bè -->
        <LinearLayout
            android:id="@+id/friend_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_friends"
                app:tint="@color/brand_primary"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có bạn bè nào"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cả hai cần theo dõi lẫn nhau\nđể trở thành bạn bè và nhắn tin"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="8dp"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_find_friends"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="🔍 Tìm người dùng"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="@drawable/bg_button_gradient"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="100dp"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
