<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_splash_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="48dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btn_back_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chỉnh sửa hồ sơ"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="36dp"
            android:text="Lưu"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:background="@drawable/bg_button_gradient"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="100dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="24dp">

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/edit_avatar"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_profile"
                        app:civ_border_color="@color/brand_primary"
                        app:civ_border_width="3dp" />

                    <TextView
                        android:id="@+id/btn_edit_avatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📷"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_button_gradient"
                        android:layout_gravity="bottom|end"
                        android:padding="2dp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhấn để thay đổi ảnh đại diện"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Form fields -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN CÁ NHÂN"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingHorizontal="20dp"
                android:paddingBottom="8dp" />

            <!-- Tên hiển thị -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:hint="Tên hiển thị"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_display_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textPersonName"
                    android:maxLength="30" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tên người dùng (username / handle) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:hint="Tên người dùng (@username)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textNoSuggestions"
                    android:maxLength="20" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tiểu sử -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:hint="Tiểu sử"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="5"
                    android:maxLength="150"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHẾ ĐỘ HIỂN THỊ"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <!-- Hồ sơ công khai / riêng tư -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔒" android:textSize="18sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Hồ sơ riêng tư"
                    android:textColor="@color/text_primary" android:textSize="15sp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_private_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    app:thumbTint="@color/brand_primary"
                    app:trackTint="@color/brand_primary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
