<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="600dp"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="32dp">

        <!-- Back -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="Quay lại"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Icon + Title -->
        <TextView
            android:id="@+id/otp_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📩"
            android:textSize="48sp"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/otp_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Xác nhận Email"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/otp_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/otp_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nhập mã gồm 6 chữ số mà chúng tôi vừa gửi đến email của bạn."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toBottomOf="@id/otp_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp" />

        <!-- OTP Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_otp"
            style="@style/Widget.Iiawak.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Mã xác nhận (6 số)"
            app:layout_constraintTop_toBottomOf="@id/otp_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_otp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="6"
                android:textColor="@color/text_primary"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Verify Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_verify_otp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Xác nhận"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gradient"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            app:layout_constraintTop_toBottomOf="@id/til_otp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resend_otp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gửi lại mã"
            android:textColor="@color/brand_primary"
            app:layout_constraintTop_toBottomOf="@id/btn_verify_otp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
