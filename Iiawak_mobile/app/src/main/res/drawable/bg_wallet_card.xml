<?xml version="1.0" encoding="utf-8"?>
<!-- Wallet card: pink-to-purple gradient background -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#1AFF2E9D"
        android:centerColor="#0DA855F7"
        android:endColor="#1AFF2E9D"
        android:angle="135"
        android:type="linear" />
    <corners android:radius="20dp" />
    <stroke
        android:width="1dp"
        android:color="#40FF2E9D" />
</shape>
