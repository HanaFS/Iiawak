<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <View
        android:id="@+id/splash_glow_top_left"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_glow_pink"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-160dp"
        android:layout_marginStart="-100dp" />

    <View
        android:id="@+id/splash_glow_bottom_right"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:background="@drawable/bg_glow_purple"
        android:alpha="0.65"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-80dp"
        android:layout_marginEnd="-80dp" />

    <View
        android:id="@+id/splash_glow_center"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_pink"
        android:alpha="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦"
        android:textSize="20sp"
        android:textColor="#FF2E9D"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="90dp"
        android:layout_marginStart="60dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✧"
        android:textSize="12sp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="115dp"
        android:layout_marginStart="50dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦"
        android:textSize="22sp"
        android:textColor="#9C27B0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="260dp"
        android:layout_marginEnd="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★"
        android:textSize="14sp"
        android:textColor="#FF4081"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="245dp"
        android:layout_marginEnd="65dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦"
        android:textSize="16sp"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="200dp"
        android:layout_marginStart="50dp" />

    <LinearLayout
        android:id="@+id/splash_logo_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp">

        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center">

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_glow_pink"
                android:alpha="0.65" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="124dp"
                android:layout_height="124dp"
                android:layout_gravity="center"
                app:cardCornerRadius="36dp"
                app:cardBackgroundColor="#20000000"
                app:cardElevation="0dp"
                app:strokeColor="#AAFF2E9D"
                app:strokeWidth="2dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="114dp"
                    android:layout_height="114dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="30dp"
                    app:cardBackgroundColor="#00000000"
                    app:cardElevation="0dp"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_gradient"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_pink_diamond"
                            android:contentDescription="Iiawak Logo" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:id="@+id/splash_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iiawak"
            android:textColor="@color/white"
            android:textSize="54sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#D14A66"
            android:shadowDx="0"
            android:shadowDy="6"
            android:shadowRadius="12" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/splash_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="52dp">

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>