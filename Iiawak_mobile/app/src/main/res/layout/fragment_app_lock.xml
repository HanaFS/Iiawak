<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_back_lock"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_nav_back"
        android:contentDescription="Quay lại"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/lock_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_back_lock"
        app:layout_constraintStart_toEndOf="@id/btn_back_lock"
        app:layout_constraintTop_toTopOf="@id/btn_back_lock" />

    <ImageView
        android:id="@+id/iv_lock_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="48dp"
        android:contentDescription="@string/lock_title"
        android:src="@drawable/ic_nav_profile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back_lock"
        app:tint="@color/brand_primary" />

    <TextView
        android:id="@+id/tv_lock_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/lock_set_pin"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_lock_logo" />

    <LinearLayout
        android:id="@+id/layout_pin_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_lock_instruction">

        <View android:id="@+id/pin_dot_1" android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_heart_glow" android:layout_margin="8dp" android:alpha="0.3" />
        <View android:id="@+id/pin_dot_2" android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_heart_glow" android:layout_margin="8dp" android:alpha="0.3" />
        <View android:id="@+id/pin_dot_3" android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_heart_glow" android:layout_margin="8dp" android:alpha="0.3" />
        <View android:id="@+id/pin_dot_4" android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_heart_glow" android:layout_margin="8dp" android:alpha="0.3" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/grid_keypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:alignmentMode="alignMargins"
        app:layout_constraintBottom_toTopOf="@id/btn_disable_lock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_pin_dots"
        app:layout_constraintVertical_bias="0.4">

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_1" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="1" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_2" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="2" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_3" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="3" android:layout_margin="10dp" app:cornerRadius="36dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_4" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="4" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_5" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="5" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_6" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="6" android:layout_margin="10dp" app:cornerRadius="36dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_7" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="7" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_8" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="8" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_9" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="9" android:layout_margin="10dp" app:cornerRadius="36dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_clear" style="@style/Widget.Iiawak.Button.Text" android:layout_width="72dp" android:layout_height="72dp" android:text="C" android:textColor="@color/text_secondary" android:layout_margin="10dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_0" style="@style/Widget.Iiawak.Button.Secondary" android:layout_width="72dp" android:layout_height="72dp" android:text="0" android:layout_margin="10dp" app:cornerRadius="36dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_del" style="@style/Widget.Iiawak.Button.Text" android:layout_width="72dp" android:layout_height="72dp" android:text="⌫" android:textColor="@color/text_secondary" android:layout_margin="10dp" />
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_disable_lock"
        style="@style/Widget.Iiawak.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_disable_lock"
        android:textColor="#FF5252"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>